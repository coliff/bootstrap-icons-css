{
  "root": true,
  "env": {
    "es2022": true,
    "node": true
  },
  "extends": ["eslint:recommended"],
  "ignorePatterns": ["**/*.min.*"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "overrides": [
    {
      "files": ["docs/script.js"],
      "env": {
        "browser": true
      },
      "globals": {
        "Prism": "readonly"
      }
    }
  ],
  "rules": {
    "curly": ["error", "all"],
    "dot-notation": "error",
    "eqeqeq": ["error", "always", { "null": "ignore" }],
    "no-throw-literal": "error",
    "no-undef": "error",
    "no-unused-vars": [
      "error",
      {
        "argsIgnorePattern": "^_",
        "caughtErrors": "none",
        "varsIgnorePattern": "^_"
      }
    ],
    "no-var": "error",
    "object-shorthand": "error",
    "prefer-const": ["error", { "ignoreReadBeforeAssign": true }],
    "prefer-template": "error",
    "radix": "error"
  }
}
