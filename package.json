{
  "name": "bootstrap-icons-css",
  "version": "1.13.1",
  "description": "CSS variables for Bootstrap Icons",
  "homepage": "https://coliff.github.io/bootstrap-icons-css/docs/",
  "bugs": {
    "url": "https://github.com/coliff/bootstrap-icons-css/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coliff/bootstrap-icons-css.git"
  },
  "license": "MIT",
  "author": "Christian Oliff (https://christianoliff.com)",
  "scripts": {
    "build": "node build-css.mjs",
    "lint": "npm run lint-html && npm run lint-css && npm run lint-js",
    "lint-css": "npx stylelint \"**/*.css\" --fix",
    "lint-html": "npx htmlhint **/*.html",
    "lint-js": "npx eslint@8 **/*.mjs --fix",
    "pa11y": "npx pa11y https://coliff.github.io/bootstrap-icons-css/docs/",
    "prettier": "npx prettier --write \"docs/**/*.{css,html,js,svg}\"",
    "serve": "npx serve .",
    "spellcheck": "npx cspell \"**/*.html\" \"**/*.md\" \"**/*.mjs\" --no-progress"
  },
  "devDependencies": {
    "clean-css": "5.3.3",
    "sharp": "0.34.5",
    "svgo": "4.0.1",
    "yauzl": "3.2.1"
  },
  "volta": {
    "node": "24.14.1"
  }
}
